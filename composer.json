{
    "name": "psc-acme/helper-shipping",
    "description": "Package helper-shipping for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\HelperShipping\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "symfony/finder": "^7.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "infection/infection": "^0.27"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}